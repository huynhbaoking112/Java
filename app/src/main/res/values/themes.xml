<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#2563EB</item>
        <item name="colorPrimaryVariant">#1D4ED8</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="colorSecondary">#059669</item>
        <item name="colorOnSecondary">#FFFFFFFF</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#F7F8FA</item>
        <item name="android:navigationBarColor">#FFFFFFFF</item>
        <item name="materialButtonStyle">@style/Widget.TaskManager.Button</item>
        <item name="textInputStyle">@style/Widget.TaskManager.TextInputLayout</item>
    </style>

    <style name="Widget.TaskManager.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.TaskManager.OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.TaskManager.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxStrokeColor">#2563EB</item>
        <item name="hintTextColor">#2563EB</item>
    </style>
</resources>
