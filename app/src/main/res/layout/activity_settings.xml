<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cài đặt"
                android:textColor="@color/auth_title"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chọn giao diện sáng, tối hoặc theo cài đặt hệ thống."
                android:textColor="@color/auth_body"
                android:textSize="15sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Giao diện"
                        android:textColor="@color/auth_title"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Lựa chọn này sẽ được lưu và áp dụng cho toàn bộ ứng dụng."
                        android:textColor="@color/auth_body"
                        android:textSize="14sp" />

                    <RadioGroup
                        android:id="@+id/themeRadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/themeSystemRadio"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:buttonTint="@color/primary_blue"
                            android:text="Theo hệ thống"
                            android:textColor="@color/auth_title"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/themeLightRadio"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:buttonTint="@color/primary_blue"
                            android:text="Sáng"
                            android:textColor="@color/auth_title"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/themeDarkRadio"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:buttonTint="@color/primary_blue"
                            android:text="Tối"
                            android:textColor="@color/auth_title"
                            android:textSize="15sp" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/dashboardFooterMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_white"
        android:elevation="8dp"
        app:itemIconTint="@color/footer_menu_selector"
        app:itemTextColor="@color/footer_menu_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/dashboard_footer_menu" />
</LinearLayout>
