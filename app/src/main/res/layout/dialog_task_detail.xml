<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_white"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/dialogTaskDetailTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/auth_title"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogTaskDetailMetaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/auth_body"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/dialogTaskDetailDescriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/auth_body"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/dialogTaskDetailTagsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/auth_body"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Ghi chú"
                android:textColor="@color/auth_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Nhập ghi chú">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dialogTaskNoteInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogAddTaskNoteButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Thêm ghi chú" />

            <LinearLayout
                android:id="@+id/dialogTaskNotesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Đính kèm"
                android:textColor="@color/auth_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogAddTaskAttachmentButton"
                style="@style/Widget.TaskManager.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Thêm file / hình ảnh" />

            <LinearLayout
                android:id="@+id/dialogTaskAttachmentsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_white"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogEditFullTaskButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sửa công việc" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogCloseTaskDetailButton"
            style="@style/Widget.TaskManager.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Đóng" />
    </LinearLayout>
</LinearLayout>
